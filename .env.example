# ─────────────────────────────────────────────────────────────
#  TenderIQ Pakistan – Environment Variables
# ─────────────────────────────────────────────────────────────

# App
APP_NAME="TenderIQ Pakistan"
APP_ENV=development
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
DEBUG=True
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# Database
DATABASE_URL=postgresql://tenderiq:password@localhost:5432/tenderiq_db
TEST_DATABASE_URL=postgresql://tenderiq:password@localhost:5432/tenderiq_test

# Redis (Celery broker)
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-your-key-here

# CKAN / data.gov.pk
CKAN_BASE_URL=https://data.gov.pk
CKAN_API_KEY=                        # optional – leave blank for public datasets

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Easypaisa (JazzCash compatible)
EASYPAISA_MERCHANT_ID=your_merchant_id
EASYPAISA_PASSWORD=your_password
EASYPAISA_INTEGRITY_SALT=your_integrity_salt
EASYPAISA_API_URL=https://easypaisa.com.pk/easypaisa/rest/v4/initPaymentRequest

# Email (Resend)
RESEND_API_KEY=re_your_resend_key
FROM_EMAIL=alerts@tenderiq.pk
FROM_NAME=TenderIQ Pakistan

# Frontend URL (for email links)
FRONTEND_URL=http://localhost:3000

# Currency Exchange (exchangerate-api.com free tier)
EXCHANGE_RATE_API_KEY=your_exchange_rate_key

# JWT
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30
